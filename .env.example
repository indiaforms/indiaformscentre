# --- Backend (set these in Vercel Project Settings > Environment Variables) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace-with-a-long-random-string

# --- Frontend ---
# In production on Vercel this can be left blank/omitted since frontend and
# backend live on the same domain. Set it only if backend is hosted elsewhere.
NEXT_PUBLIC_API_URL=
